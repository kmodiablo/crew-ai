# =============================================
# Oficina de AI Apuestas - Configuration
# Copy this file to .env and fill in your keys
# =============================================

# === API KEYS ===
THE_ODDS_API_KEY=your_the_odds_api_key_here
SERPER_API_KEY=your_serper_dev_key_here

# === BANKROLL SETTINGS ===
INITIAL_BANKROLL=75.0
UNIT_SIZE_PCT=0.02          # 2% flat bet (safe starting point)
KELLY_FRACTION=0.5          # 0.5 = Half-Kelly (recommended for safety)

# === SCHEDULE / TRIGGER ===
DAILY_TRIGGER_TIME=08:00    # Time to run report automatically (ET)

# === OPTIONAL (future features) ===
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
EMAIL_NOTIFICATIONS=false